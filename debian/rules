override_dh_install:
	dh_install
	mkdir -p debian/vitexsoftware-website/usr/lib/vitexsoftware-website
	jq '.version = "'`dpkg-parsechangelog | sed -n 's/^Version: //p'| sed 's/~.*//'`'"'  debian/conf/composer.json |sponge debian/vitexsoftware-website/usr/lib/vitexsoftware-website/composer.json
override_dh_clean:
	dh_clean
