#!/usr/bin/make -f

%:
	dh $@ --with phpcomposer


override_dh_install:
	jq '.version = "'`dpkg-parsechangelog | sed -n 's/^Version: //p'| sed 's/~.*//' `'"'  debian/composer.json |sponge debian/composer.json
	dh_install
	sed -i -e 's/..\/vendor/\/usr\/lib\/vitexsoftware-website/'  debian/vitexsoftware-website/usr/share/vitexsoftware.cz/includes/VSInit.php
	sed -i -e 's/..\/i18n/\/usr\/share\/locale/g'                debian/vitexsoftware-website/usr/share/vitexsoftware.cz/includes/VSInit.php
	sed -i -e 's/\.\./\/etc\/vscz/g'            	             debian/vitexsoftware-website/usr/share/vitexsoftware.cz/includes/VSInit.php

