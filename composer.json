{
  "name": "vitexsoftware/vscz",
  "description": "VitexSoftware homepage",
  "version": "0.202.6",
  "authors": [
    {
      "name": "vitex",
      "email": "info@vitexsoftware.cz"
    }
  ],
  "minimum-stability": "dev",
  "config": {
    "allow-plugins": {
      "ergebnis/composer-normalize": true
    }
