{
  "name": "vitexsoftware/vscz",
  "description": "VitexSoftware homepage",
  "version": "0.202.6",
  "authors": [
    {
      "name": "vitex",
      "email": "info@vitexsoftware.cz"
    }
  ],
  "minimum-stability": "dev",
  "prefer-stable": true,
  "config": {
    "allow-plugins": {
      "ergebnis/composer-normalize": true
    }
  },
  "autoload": {
    "psr-4": {
      "VSCZ\\": "src/classes/",
      "VSCZ\\ui\\": "src/classes/ui/"
    }
  },
  "require": {
    "ext-fileinfo": "*",
    "league/commonmark": "*",
    "vitexsoftware/ease-bootstrap5-widgets": "1.4.2",
    "vitexsoftware/ease-fluentpdo": "1.4.2"
  },
  "require-dev": {
    "phpunit/phpunit": "*",
    "phpstan/phpstan": "*",
    "friendsofphp/php-cs-fixer": "^3.61",
    "ergebnis/composer-normalize": "^2.43",
    "ergebnis/php-cs-fixer-config": "^6.34",
    "robmorgan/phinx": "^0.16",
    "symfony/yaml": "^7.0 || ^8.0"
  },
  "type": "project"
}
